<link rel="stylesheet" href="{{ 'section-testimonials.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}</noscript>
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}
<div class="testimonials container section-{{ section.id }}-padding">
  {% unless section.settings.title == blank %}
    <h2 class="heading">
      {{ section.settings.title | escape }}
    </h2>
  {% endunless %}
  <div class="row">
    {% for block in section.blocks %}
      <div class="col-md-6 col-lg-3">
        <div class="testimonials-item">
          <div class="testimonials-top">
            <div class="testimonials-image">
              {% if block.settings.image != blank %}
                <img
                  loading="lazy"
                  src="{{ block.settings.image | image_url: width: 116, height: 116 }}"
                  class="lazyload"
                  alt="{{ block.settings.image.alt }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="testimonials-info">
              {% if block.settings.title %}
                <h4 class="testimonials-name">
                  {{ block.settings.title }}
                </h4>
              {% endif %}
              <div class="testimonials-rating">★★★★★</div>
              {% if block.settings.subtitle %}
                <div class="testimonials-role">
                  {{ block.settings.subtitle }}
                </div>
              {% endif %}
            </div>
          </div>
          {% if block.settings.text %}
            <div class="testimonial-text">
              {{ block.settings.text }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "What Our Customers Say",
      "label": "t:sections.testimonials.settings.title.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.testimonials.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.testimonials.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.testimonials.settings.image_ratio.options__3.label"
        },
        {
          "value": "circle",
          "label": "t:sections.testimonials.settings.image_ratio.options__4.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.testimonials.settings.image_ratio.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.testimonials.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.column.settings.image.label"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Emily Johnson",
          "label": "t:sections.testimonials.blocks.column.settings.title.label"
        },
        {
          "type": "text",
          "id": "subtitle",
          "default": "Customer",
          "label": "t:sections.testimonials.blocks.column.settings.title.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>“Love this shop! So many great products in one place. Fast delivery and everything comes just as described”</p>",
          "label": "t:sections.testimonials.blocks.column.settings.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.presets.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
